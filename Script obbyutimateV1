-- 3. LOGIC DỊCH CHUYỂN (TELE-PORT)
task.spawn(function()
    while true do
        task.wait(TeleSpeed)
        if AutoParkour and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            local target = getNextCheckpoint()
            if target then
                lp.Character.HumanoidRootPart.CFrame = target.CFrame + Vector3.new(0, 3, 0)
            else
                -- Nếu không tìm thấy checkpoint tiếp theo, thử bay lên phía trước
                -- (Dành cho Obby không đặt tên Stage)
                print("Đang tìm Stage tiếp theo...")
            end
        end
    end
end)

