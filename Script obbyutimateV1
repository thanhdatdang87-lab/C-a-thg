        -- MM2 thường đặt tên Stage là số hoặc "Stage", "Checkpoint"
        if (v.Name == tostring(nextStage)) or (v.Name == "Stage" and v:FindFirstChild("Value") and v.Value.Value == nextStage) then
            if v:IsA("BasePart") then return v end
